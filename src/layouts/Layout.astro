---
// 🕊️白木 原创开发 🔗gl.baimu.live
// 😎余温 原创开发 🔗https://wiki.xxdevops.cn
// 基础布局组件 - 提供页面整体框架结构

import FloatingToolbar from '../components/FloatingToolbar.vue';
import Footer from '../components/Footer.vue';
import SearchModal from '../components/SearchModal.vue';
import SeoHead from '../components/seo/SeoHead.astro';
import { seoConfig } from '../config/seo.config';
import { resolvePageSeo } from '../utils/seo';
import { getSiteUrl } from '../utils/site';
import type { SeoPageInput } from '../types/seo';

interface Props {
  /** 页面 SEO 配置（推荐） */
  seo?: SeoPageInput;
  /** 兼容旧用法：页面标题 */
  title?: string;
  /** 兼容旧用法：页面描述 */
  description?: string;
}

const { seo: seoInput, title, description } = Astro.props;

const seo = resolvePageSeo(
  seoInput ?? {
    title: title ?? seoConfig.defaultTitle,
    description,
  },
  Astro.url.pathname,
  Astro.site?.href.replace(/\/$/, '') || getSiteUrl()
);
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 🔍 SEO 组件 -->
    <SeoHead seo={seo} />

    <!-- ⚡ DNS 预解析 - 优化资源加载 -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />

    <!-- 🎨 字体预连接 - 减少字体加载延迟 -->
    <link rel="preconnect" href="/fonts/ZiHun232Hao.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="/fonts/筑紫A丸.woff2" as="font" type="font/woff2" crossorigin />

    <!-- 🔍 关键 CSS 预加载 - 优先渲染关键路径 -->
    <link rel="preload" as="style" href="/_astro/variables.scss" />

  </head>
  <body>
    <!-- 📄 页面内容 -->
    <slot />

    <!-- 🦶 页脚 - 运行时间等信息 -->
    <Footer client:load="vue" />

    <!-- 🧰 浮动工具栏 - 搜索/主题切换/回到顶部 -->
    <FloatingToolbar client:load="vue" />

    <!-- 🔍 搜索弹窗 -->
    <SearchModal client:load="vue" />

    <!-- 🔄 Service Worker 注册 - 离线缓存支持 -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then((registration) => {
              console.log('✅ Service Worker 注册成功:', registration.scope);
            })
            .catch((error) => {
              console.error('❌ Service Worker 注册失败:', error);
            });
        });
      }
    </script>
  </body>
</html>

<style lang="scss" is:global>
  // 全局字体定义与基础样式

  // 🎨 引入全局 SCSS 变量和样式（@use 必须放在最前面）
  @use '../styles/variables.scss' as *;
  @use '../styles/home-page.scss' as *;
  @use '../styles/navbar.scss' as *;

  // 🛡️ 防止 Vue 组件闪烁 - 骨架屏样式
  astro-island[client\:only="vue"] {
    display: block;
    min-height: 80px; // 导航栏最小高度
  }

  // 确保导航栏在加载前就有基本样式
  .navbar-skeleton {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(135deg, var(--navbar-transparent-bg-start) 0%, var(--navbar-transparent-bg-end) 100%);
    backdrop-filter: blur(var(--navbar-transparent-blur));
    z-index: var(--nav-z-index);
  }

  // 🔤 字体定义
  @font-face {
    font-family: 'ZiHun232Hao';
    src: url('/fonts/xnyt.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'TukusiAMaru';
    src: url('/fonts/筑紫A丸.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  // 🎨 基础样式重置
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    min-height: 100%;
    background: var(--bg-color);
  }

  body {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* 🌊 View Transition API 样式 */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  /*
   * 切换方向驱动的层级控制（比依赖 .dark-mode 更可靠）
   * 暗→亮：旧视图（暗色）在上层收缩；亮→暗：新视图（暗色）在上层展开
   */
  html[data-theme-transition="to-light"]::view-transition-old(root),
  html[data-theme-transition="to-dark"]::view-transition-new(root) {
    z-index: 9999;
  }

  html[data-theme-transition="to-light"]::view-transition-new(root),
  html[data-theme-transition="to-dark"]::view-transition-old(root) {
    z-index: 1;
  }

  // 🏷️ 标题字体
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
</style>
