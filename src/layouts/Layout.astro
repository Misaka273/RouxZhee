---
// 🕊️白木 原创开发 🔗gl.baimu.live
// 😎余温 原创开发 🔗https://wiki.xxdevops.cn
// 基础布局组件 - 提供页面整体框架结构

import FloatingToolbar from '../components/FloatingToolbar.vue';
import Footer from '../components/Footer.vue';
import SearchModal from '../components/SearchModal.vue';
import SeoHead from '../components/seo/SeoHead.astro';
import { seoConfig } from '../config/seo.config';
import { navbarConfig } from '../config/navbar.config';
import { resolvePageSeo } from '../utils/seo';
import { getSiteUrl } from '../utils/site';
import { withBase } from '../utils/base';
import type { SeoPageInput } from '../types/seo';

interface Props {
  /** 页面 SEO 配置（推荐） */
  seo?: SeoPageInput;
  /** 兼容旧用法：页面标题 */
  title?: string;
  /** 兼容旧用法：页面描述 */
  description?: string;
}

const { seo: seoInput, title, description } = Astro.props;

const seo = resolvePageSeo(
  seoInput ?? {
    title: title ?? seoConfig.defaultTitle,
    description,
  },
  Astro.url.pathname,
  Astro.site?.href.replace(/\/$/, '') || getSiteUrl()
);
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <!-- 🌗 尽早应用用户保存的主题，避免暗色模式下首屏闪烁 -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('rouxzhee-theme-preference');
          if (saved === 'dark') {
            document.documentElement.classList.add('dark-mode');
          }
        } catch (e) {
          // 忽略无痕模式等 localStorage 不可用的情况
        }
      })();
    </script>

    <!-- 🏠 预加载导航栏 LOGO，避免首屏加载时 LOGO 延迟出现 -->
    <link rel="preload" as="image" href={navbarConfig.logo.src} type="image/svg+xml" />

    <!-- 🔍 SEO 组件 -->
    <SeoHead seo={seo} />

    <!-- 🔤 全局字体定义（动态生成，自动适配子路径前缀） -->
    <style set:html={`
      @font-face {
        font-family: 'xnyt';
        src: url('${withBase('/fonts/xnyt.woff2')}') format('woff2');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'ZiHun232Hao';
        src: url('${withBase('/fonts/xnyt.woff2')}') format('woff2');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'TukusiAMaru';
        src: url('${withBase('/fonts/筑紫A丸.woff2')}') format('woff2');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    `}></style>

    <!-- ⚡ DNS 预解析 - 优化资源加载 -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />

    <!-- 🎨 字体预加载 - 减少字体加载延迟 -->
    <link rel="preload" href={withBase('/fonts/xnyt.woff2')} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={withBase('/fonts/筑紫A丸.woff2')} as="font" type="font/woff2" crossorigin />

  </head>
  <body>
    <!-- 🛡️ 导航栏骨架屏：防止 Vue hydration 前布局跳动 -->
    <div class="navbar-skeleton" id="navbar-skeleton" aria-hidden="true">
      <div class="navbar-skeleton-container">
        <div class="navbar-skeleton-brand">
          <div class="navbar-skeleton-logo"></div>
          <div class="navbar-skeleton-name"></div>
        </div>
        <div class="navbar-skeleton-menu">
          <div class="navbar-skeleton-link"></div>
          <div class="navbar-skeleton-link"></div>
          <div class="navbar-skeleton-link"></div>
        </div>
        <div class="navbar-skeleton-actions">
          <div class="navbar-skeleton-icon"></div>
          <div class="navbar-skeleton-clock"></div>
        </div>
      </div>
    </div>

    <!-- 📄 页面内容 -->
    <slot />

    <!-- 🦶 页脚 - 运行时间等信息 -->
    <Footer client:load />

    <!-- 🧰 浮动工具栏 - 搜索/主题切换/回到顶部 -->
    <FloatingToolbar client:load />

    <!-- 🔍 搜索弹窗 -->
    <SearchModal client:load />

    <!-- 🛡️ 移除骨架屏 -->
    <script is:inline>
      (function () {
        // 骨架屏存在期间，强制隐藏真实导航栏，避免胶囊菜单/社交链接的模糊背景闪现
        const navbarEls = document.querySelectorAll('.navbar, .navbar-wrapper, .navbar-menu, .navbar-social, .social-link');
        navbarEls.forEach(function (el) {
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('visibility', 'hidden', 'important');
          el.style.setProperty('backdrop-filter', 'none', 'important');
          el.style.setProperty('-webkit-backdrop-filter', 'none', 'important');
        });

        function showNavbar() {
          navbarEls.forEach(function (el) {
            el.style.removeProperty('opacity');
            el.style.removeProperty('visibility');
            el.style.removeProperty('backdrop-filter');
            el.style.removeProperty('-webkit-backdrop-filter');
          });
        }

        function removeSkeleton() {
          const skeleton = document.getElementById('navbar-skeleton');
          if (skeleton) {
            skeleton.style.opacity = '0';
            skeleton.style.visibility = 'hidden';
            setTimeout(function () {
              skeleton.remove();
              showNavbar();
            }, 300);
          } else {
            showNavbar();
          }
        }
        // Vue 组件挂载完成后移除骨架屏
        if (document.readyState === 'complete') {
          setTimeout(removeSkeleton, 100);
        } else {
          window.addEventListener('load', function () {
            setTimeout(removeSkeleton, 100);
          });
        }
        // 兜底：3秒后强制移除
        setTimeout(removeSkeleton, 3000);
      })();
    </script>

    <!-- 🔄 Service Worker 注册 - 离线缓存支持 -->
    <script is:inline define:vars={{ swUrl: withBase('/sw.js') }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl)
            .then((registration) => {
              console.log('✅ Service Worker 注册成功:', registration.scope);
            })
            .catch((error) => {
              console.error('❌ Service Worker 注册失败:', error);
            });
        });
      }
    </script>

    <!-- ✨ 光标拖尾特效 -->
    <script>
      import { useCursorTrail } from '../components/CursorTrail/useCursorTrail';
      import { cursorTrailConfig } from '../config/cursorTrail.config';

      if (cursorTrailConfig.enabled) {
        useCursorTrail();
      }
    </script>

    <!-- 🖼️ 图片查看器 -->
    <script>
      import { useImageViewer } from '../components/ImageViewer/useImageViewer';
      import { imageViewerConfig } from '../config/imageViewer.config';

      if (imageViewerConfig.enabled) {
        useImageViewer();
      }
    </script>
  </body>
</html>

<style lang="scss" is:global>
  // 全局字体定义与基础样式

  // 🎨 引入全局 SCSS 变量和样式（@use 必须放在最前面）
  @use '../styles/variables.scss' as *;
  @use '../styles/home-page.scss' as *;
  @use '../styles/navbar.scss' as *;
  @use '../styles/scrollbar.scss' as *;
  @use '../components/CursorTrail/CursorTrail.scss' as *;
  @use '../components/ImageViewer/ImageViewer.scss' as *;

  // 🛡️ 防止 Vue 组件闪烁 - 骨架屏样式
  astro-island[client\:only="vue"] {
    display: block;
    min-height: 80px; // 导航栏最小高度
  }

  // 确保导航栏在加载前就有基本样式
  .navbar-skeleton {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    z-index: calc(var(--nav-z-index, 3) + 10);
    background: transparent;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;

    .navbar-skeleton-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
      max-width: 1940px;
      margin: 0 auto;
      padding: 0 10px;
    }

    .navbar-skeleton-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 12px;
    }

    .navbar-skeleton-logo {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: transparent;
    }

    .navbar-skeleton-name {
      width: 100px;
      height: 20px;
      border-radius: 4px;
      background: transparent;
    }

    .navbar-skeleton-menu {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px;
      border-radius: 9999px;
      background: transparent;
      border: 1px solid transparent;
    }

    .navbar-skeleton-link {
      width: 60px;
      height: 28px;
      border-radius: 9999px;
      background: transparent;
    }

    .navbar-skeleton-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .navbar-skeleton-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: transparent;
    }

    .navbar-skeleton-clock {
      width: 70px;
      height: 24px;
      border-radius: 4px;
      background: transparent;
    }
  }

  // 骨架屏存在期间隐藏真实导航栏，避免胶囊菜单/社交链接的模糊背景透出
  .navbar-skeleton ~ * .navbar,
  .navbar-skeleton ~ * .navbar-wrapper,
  .navbar-skeleton ~ * .navbar-menu,
  .navbar-skeleton ~ * .navbar-social,
  .navbar-skeleton ~ * .social-link {
    opacity: 0 !important;
    visibility: hidden !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  // � 基础样式重置
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    min-height: 100%;
    background: var(--bg-color);
  }

  body {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  // 📱 移动端底部导航适配：移除顶部导航高度、预留底部安全区域
  @media (max-width: 768px) {
    :root {
      --nav-height: 0px;
    }

    body {
      padding-bottom: calc(
        var(--mobile-bottom-nav-height) +
        var(--mobile-bottom-nav-bump-height) +
        env(safe-area-inset-bottom)
      );
    }
  }

  /* 🌊 View Transition API 样式 */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  /*
   * 切换方向驱动的层级控制（比依赖 .dark-mode 更可靠）
   * 暗→亮：旧视图（暗色）在上层收缩；亮→暗：新视图（暗色）在上层展开
   */
  html[data-theme-transition="to-light"]::view-transition-old(root),
  html[data-theme-transition="to-dark"]::view-transition-new(root) {
    z-index: 9999;
  }

  html[data-theme-transition="to-light"]::view-transition-new(root),
  html[data-theme-transition="to-dark"]::view-transition-old(root) {
    z-index: 1;
  }

  // 🏷️ 标题字体
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
</style>
