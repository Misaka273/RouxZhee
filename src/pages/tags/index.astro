---
// 🕊️白木 原创开发 🔗gl.baimu.live
// 😎余温 原创开发 🔗https://wiki.xxdevops.cn
// 🏷️ 标签云落地页

import { resolve } from 'path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.vue';
import CloudPage from '../../components/CloudPage.vue';
import { createPageSeo } from '../../utils/seo';
import { seoConfig } from '../../config/seo.config';
import { getTagCloud } from '../../utils/siteOverview';
import { bloggerConfig } from '../../config/blogger.config';

// 📁 文档目录
const docDir = resolve(process.cwd(), 'doc');

// ☁️ 读取所有文档标签
const tags = getTagCloud(docDir);

const seo = createPageSeo({
  title: `文档标签 - ${seoConfig.siteName}`,
  description: `浏览 ${seoConfig.siteName} 的所有文档标签，共 ${tags.length} 个`,
  type: 'website',
});
---

<Layout seo={seo}>
  <!-- 🧭 独立导航栏（保持常驻） -->
  <Navbar client:load="vue" disable-auto-hide />

  <!-- 🏷️ 全屏标签云 -->
  <CloudPage
    client:load="vue"
    title={bloggerConfig.cloud.tag.title}
    icon={bloggerConfig.cloud.tag.icon}
    item-label="标签"
    items={tags}
    link-prefix="/tags"
  />
</Layout>
